.page-shell {
  min-height: 100vh;
  padding: 32rpx;
  background: #f5f7fa;
  box-sizing: border-box;
}

.page-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #1f2937;
}

.page-copy {
  margin-top: 16rpx;
  color: #4b5563;
  font-size: 28rpx;
}

.btn-primary,
.filter-tab {
  margin-top: 24rpx;
}

.tab-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 24rpx;
}
