{
  "projectPath": "<project-root>",
  "outputRoot": "<project-root>/.tmp/gui-check",
  "routes": [
    {
      "key": "home",
      "route": "/pages/home/index",
      "expectedPath": "pages/home/index",
      "primarySelector": ".page-shell",
      "titleSelector": ".page-title",
      "settleMs": 1600,
      "dataFields": [
        "loading",
        "errorMessage"
      ],
      "actions": [
        {
          "type": "tap",
          "selector": ".btn-primary",
          "waitMs": 1200,
          "required": false
        }
      ]
    },
    {
      "key": "tasks",
      "route": "/pages/tasks/index",
      "expectedPath": "pages/tasks/index",
      "primarySelector": ".page-shell",
      "titleSelector": ".page-title",
      "settleMs": 1600,
      "dataFields": [
        "loading",
        "errorMessage",
        "activeScope"
      ],
      "actions": [
        {
          "type": "tap",
          "selector": ".filter-tab",
          "index": 1,
          "all": true,
          "waitMs": 800,
          "required": false
        }
      ]
    }
  ]
}
